{
  "manifest_version": 3,
  "name": "Quick Directions",
  "version": "2.1.0",
  "description": "Highlight any address for instant directions or build multi-stop trips with route optimization.",
  "permissions": ["contextMenus", "storage", "sidePanel", "tabs"],
  "host_permissions": [
    "https://nominatim.openstreetmap.org/",
    "https://maps.googleapis.com/"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://www.google.com"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Quick Directions"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
