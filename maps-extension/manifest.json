{
  "manifest_version": 3,
  "name": "Quick Directions",
  "version": "1.0.0",
  "description": "Highlight any address and get cycling, transit, or driving directions.",
  "permissions": ["contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Directions Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
